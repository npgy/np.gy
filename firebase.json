{
  "hosting": {
    "public": "_site",
    "appAssociation": "AUTO",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [{
    	"source": "/resume",
    	"destination": "/resume/resume.pdf"
    },
	{
		"source": "/l/**",
		"dynamicLinks": true }
	],
	"redirects": [ {
	    "source": "/gullible",
	    "destination": "https://www.youtube.com/watch?v=dQw4w9WgXcQ",
	    "type": 301
  	},
    {
      "source": "/states",
      "destination": "https://docs.google.com/spreadsheets/d/1nJzi5EKrzGYV-6VEgMRgmwSuyXQoH2lonBxNd-k1Fgg",
      "type": 301
    },
    {
      "source": "/datawave",
      "destination": "https://open.spotify.com/playlist/2ona5aFJACCb2qLm3dpmEt",
      "type": 301
    } ]
  }
}
